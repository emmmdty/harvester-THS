# 复制本文件为 .env 后再填写。
# 非技术同事只需要重点填写飞书相关配置；不知道怎么填时，把飞书表格链接发给技术同事。

# 飞书应用凭证
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 飞书表格信息：Wiki 链接填 FEISHU_WIKI_TOKEN；普通表格链接填 FEISHU_SPREADSHEET_TOKEN。
FEISHU_WIKI_TOKEN=
FEISHU_SPREADSHEET_TOKEN=

# 三个平台和 Step 1.5 输出表的 sheet id。
FEISHU_SHEET_DOUYIN=
FEISHU_SHEET_XHS=
FEISHU_SHEET_BILIBILI=
FEISHU_SHEET_STEP15_FILTERED=
FEISHU_SHEET_DOUYIN_HISTORY=
FEISHU_SHEET_XHS_HISTORY=
FEISHU_SHEET_BILIBILI_HISTORY=
FEISHU_OPEN_BASE_URL=https://open.feishu.cn

# 内容类型兜底识别配置。不会用可以先留空。
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# 抖音渠道内容分级 MiniMax 配置。
# 当前独立分类模块不读取 STEP15_ASR_COMMAND / STEP15_OCR_COMMAND。
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M3
MINIMAX_IMAGE_UNDERSTANDING_ENDPOINT=

# 素材下载配置。默认会临时导出本机登录目录 Cookie 给 yt-dlp，并优先下载低清素材用于 AI 分析。
MATERIAL_EXPORT_PROFILE_COOKIES=1
MATERIAL_YTDLP_FORMAT=worstvideo*+bestaudio/worst/best
MATERIAL_YTDLP_RETRIES=5
MATERIAL_YTDLP_FRAGMENT_RETRIES=5
MATERIAL_YTDLP_COOKIES=
DOUYIN_MATERIAL_YTDLP_COOKIES=
XHS_MATERIAL_YTDLP_COOKIES=
BILIBILI_MATERIAL_YTDLP_COOKIES=
MATERIAL_YTDLP_EXTRA_ARGS=

# Step 1.5 抖音筛选配置。不会用可以保持默认或留空。
FILTER_PROVIDER=qwen
FILTER_STRICTNESS=balanced
FILTER_TARGET_PASS_RATE=0.4
FILTER_MIN_PASS_RATE=0.33
FILTER_MAX_PASS_RATE=0.5
STEP15_ASR_COMMAND=
STEP15_OCR_COMMAND=
QWEN_API_KEY=
QWEN_MODEL=qwen3-vl-plus
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1

# 面板监听地址。留空表示本机使用；局域网共享时填 0.0.0.0。
HOST=
